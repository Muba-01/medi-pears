{
  "name": "contracts",
  "version": "1.0.0",
  "description": "MediPears smart contracts",
  "scripts": {
    "build": "hardhat compile",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:all": "npm run compile && npm run test && npm run deploy:local",
    "preflight:local": "ts-node scripts/preflight.ts hardhat",
    "preflight:sepolia": "ts-node scripts/preflight.ts sepolia",
    "deploy:local": "npm run preflight:local && hardhat run scripts/deploy.ts",
    "deploy:sepolia": "npm run preflight:sepolia && hardhat run scripts/deploy.ts --network sepolia"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "hardhat": "^2.28.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  }
}
